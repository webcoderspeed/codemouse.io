# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://codemouse.io
NEXTAUTH_SECRET=           # generate: openssl rand -base64 32

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free cluster at mongodb.com/atlas → Get connection string → paste here
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/codemouse?retryWrites=true&w=majority

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=                      # Settings > GitHub App > App ID
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=              # Set when creating the GitHub App
GITHUB_CLIENT_ID=                   # GitHub App > OAuth Client ID
GITHUB_CLIENT_SECRET=               # GitHub App > OAuth Client Secret
NEXT_PUBLIC_GITHUB_APP_SLUG=codemouse   # The URL slug of your GitHub App

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...          # platform.openai.com → API Keys

# ─── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...        # Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_SECRET=                # Razorpay Dashboard → Settings → API Keys

# ─── SMTP / Nodemailer ────────────────────────────────────────────────────────
# Option A: Gmail (easiest for MVP)
#   1. Enable 2FA on your Gmail account
#   2. Go to Google Account → Security → App Passwords → create one
#   3. Use that App Password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx      # 16-char App Password (NOT your Gmail password)
SMTP_FROM=CodeMouse 🐭 <your@gmail.com>

# Option B: Brevo (free 300 emails/day — recommended for production)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=noreply@codemouse.io

# Option C: Zoho Mail (free with custom domain)
# SMTP_HOST=smtp.zoho.in
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@codemouse.io
# SMTP_PASS=your-zoho-password
# SMTP_FROM=noreply@codemouse.io
