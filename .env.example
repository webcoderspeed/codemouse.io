# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://codemouse.io
NEXTAUTH_SECRET=           # openssl rand -base64 32

# ─── Encryption (for API keys stored in DB) ───────────────────────────────────
# Must be exactly 64 hex chars (= 32 bytes for AES-256)
# Generate with:  openssl rand -hex 32
ENCRYPTION_KEY=            # openssl rand -hex 32

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Free cluster → mongodb.com/atlas → Create cluster → Get connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/codemouse?retryWrites=true&w=majority

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=                      # Settings → Developer Settings → GitHub Apps → App ID
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=              # Random secret you set when creating the GitHub App
GITHUB_CLIENT_ID=                   # GitHub App → OAuth Credentials → Client ID
GITHUB_CLIENT_SECRET=               # GitHub App → OAuth Credentials → Client Secret
NEXT_PUBLIC_GITHUB_APP_SLUG=codemouseio   # Slug from your GitHub App URL

# ─── SMTP / Nodemailer ────────────────────────────────────────────────────────
# Option A: Gmail  (easiest — good for MVP)
#   1. Enable 2FA on Gmail
#   2. Google Account → Security → App Passwords → Generate
#   3. Use the 16-char App Password (NOT your real Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=CodeMouse <your@gmail.com>

# Option B: Brevo (free 300 emails/day — recommended for production)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM=noreply@codemouse.io

# ─── NO PAYMENT KEYS NEEDED ───────────────────────────────────────────────────
# CodeMouse is free. Users add their own OpenAI API key via the Settings page.
# The key is stored securely in MongoDB per-user and used server-side only.
